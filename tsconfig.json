{
	"compilerOptions": {
		"target": "ESNext",
		"useDefineForClassFields": true,
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"module": "ESNext",
		"skipLibCheck": true,
		"noErrorTruncation": true,
		"allowJs": true,
		/* Bundler mode */
		"moduleResolution": "bundler",
		"resolvePackageJsonExports": false,
		"allowImportingTsExtensions": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"noEmit": true,
		"jsx": "react-jsx",
		/* Linting */
		"strict": true,
		/*Alias Paths */
		"baseUrl": ".",
		//Path alias' names need to be mirrored in eslintrc.cjs config file 
		"paths": {
			"@/test/*": [
				"./test/*"
			],
			"@/*": [
				"./src/*"
			],
			"@scss/*": [
				"src/common/scss/*"
			],
		},
		"types": [
			"node",
			"vitest/importMeta",
			"vitest/globals"
		]
	},
	"include": [
		"src",
		"test"
	],
	"references": [
		{
			"path": "./tsconfig.node.json"
		}
	]
}