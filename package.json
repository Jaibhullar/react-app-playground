{
  "name": "react-app-playground",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "vite --open --host",
    "watch-scss": "npx @tsjam/typed-scss-modules \"src/**/*.module.scss\" --aliasPrefixes.@scss src/common/scss --watch",
    "test": "vitest run",
    "lint": "eslint src/**/*.ts*  --max-warnings 0 & stylelint src/**/*.scss",
    "build": "tsc --p ./tsconfig.build.json && vite build",
    "preview": "tsc --p ./tsconfig.build.json && vite build --mode preview && vite preview --mode preview --open"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.20",
    "lucide-react": "^1.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.7.1",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsjam/typed-scss-modules": "10.2.0",
    "@types/node": "^22.19.8",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitejs/plugin-react-swc": "^4.2.3",
    "@vitest/ui": "^4.0.18",
    "eslint": "^9.39.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-testing-library": "^7.15.4",
    "globals": "^17.3.0",
    "jsdom": "^28.0.0",
    "msw": "^2.12.8",
    "sass": "^1.97.3",
    "stylelint": "^17.1.1",
    "stylelint-config-css-modules": "^4.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
